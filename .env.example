DOCKER_BIND_RUNS_DIR=
SANDBOX_CODEX_AUTH_INCLUDE=auth.json,credentials.json,token.json,*auth*.json,*token*.json,*credential*.json,*session*.json
SANDBOX_CODEX_AUTH_TAG=
CODEX_AUTH_ENCRYPTION_KEY=
CODEX_AUTH_MAX_FILE_BYTES=262144
CODEX_JSONL_LIVE_LOG_ONLY=1
CODEX_FLAG_VERIFY_MCP_ENABLED=1
SANDBOX_IDA_HOST_PATH=
SANDBOX_IDA_MOUNT_PATH=/opt/ida
SANDBOX_IDALIB_MCP_PORT=8745
DISCORD_WEBHOOK_URL=
DISCORD_NOTIFY_ON_FLAG=true
DISCORD_NOTIFY_INCLUDE_FLAG=true
